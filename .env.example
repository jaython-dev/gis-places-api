# Django Config
SECRET_KEY=replace-with-your-secret-key
DEBUG=True

# Database Config (Default matches docker-compose setup)
DB_NAME=gisdb
DB_USER=gisuser
DB_PASSWORD=gispass
DB_HOST=127.0.0.1
DB_PORT=5433

# Foursquare API Config
# Obtain a v3 API key (starts with 'fsq3_') from developer.foursquare.com
FSQ_API_KEY=your_foursquare_v3_api_key_here
# Search Mode: "locality" (efficient, ~44 calls total) or "grid" (exhaustive coordinate search, 240+ calls total)
SEARCH_MODE=locality
